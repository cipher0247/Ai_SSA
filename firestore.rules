rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reports
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - The UID of the user who owns this report
    //   - sportType: string (required) - The type of sport analyzed
    //   - formation: string (required) - The detected formation
    //   - strategy: string (required) - The detected strategy
    //   - counterStrategy: string (required) - The suggested counter strategy
    //   - confidence: number (required, 0-1) - The AI's confidence level
    //   - playerPerformanceScore: number (required, 0-100) - Overall team performance score
    //   - playerStats: list (required) - Array of player statistics objects
    //   - comparisonData: list (optional) - Array of player comparison data objects
    //   - createdAt: timestamp (required, immutable) - When the report was created
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'sportType', 'formation', 'strategy', 'counterStrategy', 'confidence', 'playerPerformanceScore', 'playerStats', 'createdAt']) &&
             data.userId is string &&
             data.sportType is string && data.sportType.size() > 0 && data.sportType.size() < 100 &&
             data.formation is string && data.formation.size() > 0 && data.formation.size() < 100 &&
             data.strategy is string && data.strategy.size() > 0 && data.strategy.size() < 1000 &&
             data.counterStrategy is string && data.counterStrategy.size() > 0 && data.counterStrategy.size() < 2000 &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 1 &&
             data.playerPerformanceScore is number && data.playerPerformanceScore >= 0 && data.playerPerformanceScore <= 100 &&
             data.playerStats is list && data.playerStats.size() <= 50 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /reports/{reportId} {
      // Allow users to read only their own reports
      allow read: if isDocOwner();
      
      // Allow users to create reports for themselves
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidReport(request.resource.data);
      
      // Reports are generally immutable once created in this app
      allow update: if false;
      
      // Allow users to delete their own reports
      allow delete: if isDocOwner();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
